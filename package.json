{
  "name": "@openlatex/root",
  "description": "Local filesystem-backed LaTeX editor with live preview and Git integration",
  "version": "0.0.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/xTazah/OpenLatex"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "pnpm turbo dev --filter=@openlatex/web",
    "lint": "pnpm exec biome check",
    "lint:fix": "pnpm exec biome check --fix"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.13",
    "turbo": "^2.7.6"
  },
  "packageManager": "pnpm@10.28.2"
}
